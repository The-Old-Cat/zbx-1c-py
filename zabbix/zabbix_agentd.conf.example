# ============================================
# Файл конфигурации Zabbix Agent (классический)
# ============================================
# Расположение: C:\Program Files\Zabbix Agent\zabbix_agentd.conf
# Версия: Zabbix Agent 7.0.23 (классический, на C)
# ============================================

# ------------------------------
# НАСТРОЙКИ ЛОГИРОВАНИЯ
# ------------------------------

### Тип вывода логов
# file - запись в файл
# system - запись в системный журнал (Windows Event Log)
# console - вывод на консоль
LogType=file

### Путь к файлу лога (актуально для LogType=file)
LogFile=C:\Program Files\Zabbix Agent\zabbix_agentd.log

### Уровень детализации лога
# 0 - базовое логирование (информация о запуске/остановке)
# 1 - критичные ошибки
# 2 - предупреждения
# 3 - отладочная информация (полезно при поиске проблем)
# 4 - детальная отладочная информация (только для разработки)
# 5 - максимально подробная информация (может сильно нагружать диск)
DebugLevel=3


# ------------------------------
# НАСТРОЙКИ ПОДКЛЮЧЕНИЯ К СЕРВЕРУ
# ------------------------------

### Список Zabbix серверов (или прокси), которые могут опрашивать агента
# Формат: IP-адрес или DNS-имя (через запятую)
# Можно указать несколько адресов через запятую
#Server=127.0.0.1,192.168.0.233
Server=127.0.0.1,<IP-АДРЕС_ВАШЕГО_СЕРВЕРА_ZABBIX>

### Адрес Zabbix сервера для активных проверок (Active checks)
# Активные проверки — когда агент сам инициирует соединение с сервером
#ServerActive=192.168.0.233
ServerActive=<IP-АДРЕС_ВАШЕГО_СЕРВЕРА_ZABBIX>

### Уникальное имя хоста в Zabbix
# Должно совпадать с именем, указанным в веб-интерфейсе для этого узла сети
#Hostname=SRV-PINAVTO01
Hostname=<ИМЯ_ВАШЕГО_ХОСТА_В_ZABBIX>


# ------------------------------
# ОБЩИЕ НАСТРОЙКИ
# ------------------------------

### Таймаут выполнения проверок (в секундах)
# Если проверка (например, скрипт) выполняется дольше, она будет прервана
Timeout=30

### Разрешить выполнение системных команд через ключ system.run[*]
# Это мощная, но потенциально опасная возможность. 
# Используйте только если действительно нужно и контролируйте,
# какие команды могут выполняться (через AllowKey).
AllowKey=system.run[*]

### Логировать все выполняемые команды (для отладки)
# 0 - не логировать
# 1 - логировать
# Полезно при отладке UserParameter, но в проде лучше отключить.
LogRemoteCommands=1


# ------------------------------
# ПОДКЛЮЧЕНИЕ ДОПОЛНИТЕЛЬНЫХ ФАЙЛОВ КОНФИГУРАЦИИ
# ------------------------------

### Директория для дополнительных .conf файлов
# Сюда можно класть отдельные файлы с пользовательскими параметрами
# (например, ваш файл для мониторинга 1С)
Include=C:\Program Files\Zabbix Agent\zabbix_agentd.d


# ============================================
# ПРИМЕРЫ ПОЛЕЗНЫХ ДОПОЛНИТЕЛЬНЫХ ПАРАМЕТРОВ
# ============================================

### Пользователь, от которого запускаются проверки (только для Windows)
# По умолчанию: SYSTEM
# Если нужно запускать скрипты от конкретного пользователя, 
# можно указать в формате "Домен\Пользователь"
#User=MYDOMAIN\zabbix_user

### Максимальное количество одновременно выполняющихся проверок
# По умолчанию: 100
# Если скрипты долгие и их много, можно увеличить
#StartAgents=5

### Порт, на котором агент слушает соединения (пассивные проверки)
# По умолчанию: 10050
#ListenPort=10050

### IP-адрес, на котором агент слушает соединения
# По умолчанию: 0.0.0.0 (все интерфейсы)
#ListenIP=0.0.0.0

### Список разрешенных ключей (для дополнительной безопасности)
# Например, можно разрешить только определенные system.run команды
#AllowKey=system.run[ping 8.8.8.8,*]
#DenyKey=system.run[rm -rf /*]