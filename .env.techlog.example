# ===========================================
# Пример конфигурации для zbx-1c-techlog
# ===========================================
# Скопируйте этот файл в .env.techlog и настройте под вашу среду
# ===========================================

# -------------------------------------------
# Путь к техжурналу 1С
# -------------------------------------------
# Windows:
TECHJOURNAL_LOG_BASE=C:/1c_log

# Linux:
# TECHJOURNAL_LOG_BASE=/var/log/1c/techlog

# macOS:
# TECHJOURNAL_LOG_BASE=~/Library/Logs/1C/techlog

# -------------------------------------------
# Путь к директории для логов самого мониторинга
# -------------------------------------------
# Windows:
LOG_PATH=G:/logs/zbx-1c-techlog

# Linux:
# LOG_PATH=/var/log/zbx-1c-techlog

# macOS:
# LOG_PATH=~/Library/Logs/zbx-1c-techlog

# -------------------------------------------
# Режим отладки
# -------------------------------------------
DEBUG=false

# -------------------------------------------
# Период сбора метрик (минуты)
# -------------------------------------------
PERIOD=5

# -------------------------------------------
# Zabbix (опционально)
# -------------------------------------------
# Сервер Zabbix для отправки через zabbix_sender
ZABBIX_SERVER=127.0.0.1
ZABBIX_PORT=10051

# Имя хоста в Zabbix (должно совпадать с настроенным хостом)
ZABBIX_HOSTNAME=1c-server

# Использовать Zabbix API вместо zabbix_sender
ZABBIX_USE_API=false

# URL и токен для Zabbix API (если ZABBIX_USE_API=true)
# ZABBIX_API_URL=http://zabbix.example.com/api_jsonrpc.php
# ZABBIX_API_TOKEN=your_api_token_here

# -------------------------------------------
# Фильтры событий (опционально)
# -------------------------------------------
# Минимальный уровень событий для сбора
# 0 = Все, 1 = Ошибки, 2 = Предупреждения, 3 = Инфо
# MIN_EVENT_LEVEL=0

# Игнорировать события от пользователей (список через запятую)
# IGNORE_USERS=ServiceUser,BackupUser

# Игнорировать события из информационных баз (список через запятую)
# IGNORE_INFOBASES=TestIB,BackupIB
