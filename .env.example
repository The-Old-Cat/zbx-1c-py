# =============================================================
# ТЕХЖУРНАЛ 1С (мониторинг через логи)
# =============================================================

# Базовый путь к логам техжурнала (переменная для logcfg.xml)
# В logcfg.xml используется как {{LOG_BASE}}/core, {{LOG_BASE}}/perf и т.д.
#
# Примеры для разных ОС:
#   Windows: TECHJOURNAL_LOG_BASE=C:/1c_log
#   Linux:   TECHJOURNAL_LOG_BASE=/var/log/1c/techjournal
TECHJOURNAL_LOG_BASE=C:/1c_log
TECHJOURNAL_LOG_ANALYTICS=C:/1c_log_analytics

# Период сбора метрик (минуты)
TECHJOURNAL_PERIOD_MINUTES=5

# Логи самого мониторинга
LOG_PATH=./logs

# Режим отладки
DEBUG=False

# =============================================================
# ZABBIX INTEGRATION (для отправки метрик техжурнала)
# =============================================================

# Адрес сервера Zabbix для zabbix_sender
ZABBIX_SERVER=127.0.0.1
ZABBIX_PORT=10051

# Путь к утилите zabbix_sender (опционально, ищется в PATH)
# Windows: ZABBIX_SENDER_PATH=C:/Program Files/Zabbix Agent/zabbix_sender.exe
# Linux:   ZABBIX_SENDER_PATH=/usr/bin/zabbix_sender
# ZABBIX_SENDER_PATH=

# Использовать Zabbix API вместо zabbix_sender
ZABBIX_USE_API=false

# URL и токен для Zabbix API (если ZABBIX_USE_API=true)
# ZABBIX_API_URL=http://zabbix.example.com/api_jsonrpc.php
# ZABBIX_API_TOKEN=your_api_token_here
