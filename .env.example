# =============================================================
# ТЕХЖУРНАЛ 1С (мониторинг через логи)
# =============================================================

# ---------------------------------------------------------------------------
# Учётные данные администратора (для Apache deployment)
# ---------------------------------------------------------------------------
ADMIN_USERNAME=
ADMIN_PASSWORD=
REQUIRE_ADMIN=true
ELEVATION_MODE=auto

# ---------------------------------------------------------------------------
# ОБЩИЕ НАСТРОЙКИ
# ---------------------------------------------------------------------------

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Режим отладки: true / false
DEBUG=false

# Таймаут загрузки (секунды)
DOWNLOAD_TIMEOUT=300

# ---------------------------------------------------------------------------
# ПУТИ К ЛОГАМ (техжурнал 1С и мониторинг)
# ---------------------------------------------------------------------------

# Базовый путь к логам техжурнала 1С
# Windows: TECHJOURNAL_LOG_BASE=C:/1c_log
# Linux:   TECHJOURNAL_LOG_BASE=/var/log/1c/techjournal
# macOS:   TECHJOURNAL_LOG_BASE=~/Library/Logs/1C/techlog
TECHJOURNAL_LOG_BASE=C:/1c_log

# Путь к аналитическим логам 1С
# Windows: TECHJOURNAL_LOG_ANALYTICS=C:/1c_log_analytics
# Linux:   TECHJOURNAL_LOG_ANALYTICS=/var/log/1c/techlog_analytics
TECHJOURNAL_LOG_ANALYTICS=C:/1c_log_analytics

# Период сбора метрик техжурнала (минуты)
TECHJOURNAL_PERIOD_MINUTES=5

# Дирекория для логов мониторинга
# Windows: LOG_PATH=G:/logs/zbx-1c-techlog
# Linux:   LOG_PATH=/var/log/zbx-1c-techlog
# macOS:   LOG_PATH=~/Library/Logs/zbx-1c-techlog
LOG_PATH=./logs

# Файл для логов Apache deployment (пусто = рядом со скриптом)
# LOG_FILE=

# ---------------------------------------------------------------------------
# ZABBIX INTEGRATION
# ---------------------------------------------------------------------------

# Адрес сервера Zabbix для zabbix_sender
ZABBIX_SERVER=
ZABBIX_PORT=10051

# Имя хоста в Zabbix (должно совпадать с настроенным хостом)
ZABBIX_HOSTNAME=1c-server

# Путь к утилите zabbix_sender (опционально, ищется в PATH)
# Windows: ZABBIX_SENDER_PATH=C:/Program Files/Zabbix Agent/zabbix_sender.exe
# Linux:   ZABBIX_SENDER_PATH=/usr/bin/zabbix_sender
# ZABBIX_SENDER_PATH=

# Использовать Zabbix API вместо zabbix_sender
ZABBIX_USE_API=false

# URL и токен для Zabbix API (если ZABBIX_USE_API=true)
# ZABBIX_API_URL=http://zabbix.example.com/api_jsonrpc.php
# ZABBIX_API_TOKEN=your_api_token_here

# Фильтры событий техжурнала (опционально)
# Минимальный уровень: 0=Все, 1=Ошибки, 2=Предупреждения, 3=Инфо
# MIN_EVENT_LEVEL=0
# IGNORE_USERS=ServiceUser,BackupUser
# IGNORE_INFOBASES=TestIB,BackupIB

# ---------------------------------------------------------------------------
# СЕРВЕР 1С:Предприятия (публикация + мониторинг)
# ---------------------------------------------------------------------------

# Адрес и порт сервера 1С
SERVER_1C_HOST=localhost
SERVER_1C_PORT=1545

# RAS сервер (для получения списка баз)
RAS_SERVER=localhost:1545

# Имя кластера 1С (если несколько кластеров)
# SERVER_1C_CLUSTER=MyCluster

# Аутентификация администратора кластера 1С
SERVER_1C_USER=
SERVER_1C_PASSWORD=


# ---------------------------------------------------------------------------
# АВТОПУБЛИКАЦИЯ 1С (zbx-1c-publisher)
# Если тип публикации: prod, то Режим публикации: FULL
# Если тип публикации: tech, то Режим публикации: THIN
# ---------------------------------------------------------------------------

# Тип публикации: prod или tech
# PUBLISH_TYPE=prod
PUBLISH_TYPE=tech


# Режим публикации: FULL (все сервисы) или THIN (только OData/Аналитика)
# Режим: FULL создаёт full.vrd, THIN создаёт thin.vrd
# PUBLISH_MODE=FULL
PUBLISH_MODE=THIN

# Путь к webinst.exe (если не указан — ищется в PATH)
# Windows: WEBINST_PATH=C:/Program Files/1cv8/8.3.х.х.х/bin/webinst.exe
# Linux:   WEBINST_PATH=/opt/1cv8/webinst
WEBINST_PATH=C:/Program Files/1cv8/8.3.27.2074/bin/webinst.exe


# Корневая директория для публикации веб-сервисов
# Windows: PUBLISH_ROOT=C:/Apache24/htdocs
# Linux:   PUBLISH_ROOT=/var/www/htdocs
PUBLISH_ROOT=C:/Apache24/htdocs

# Суффикс для технических имён баз
TECH_SUFFIX=_mg

# Путь к конфигурации Apache
# Windows: APACHE_CONF_PATH=C:/Apache24/conf/httpd.conf
# Linux:   APACHE_CONF_PATH=/etc/apache2/apache2.conf
APACHE_CONF_PATH=C:/Apache24/conf/httpd.conf

# Пути к бинарникам 1С (для Linux)
ONEC_BIN_PATH_LINUX=auto
ONEC_BIN_PATH_WIN=auto
# =========================================================
# Версия платформы 1С:Предприятия
# =========================================================
ONEC_VERSION=8.3.27.2074

# Префиксы баз для публикации (пусто = все базы)
# BASE_PREFIX=prod_,test_

# Исключения (базы, которые не нужно публиковать)
# BASE_EXCLUDE=ArchivedBase,TestBase

# Автоматически перезапускать Apache после публикации
AUTO_RESTART_APACHE=true


# =========================================================
# Логирование публикатора 
# DEBUG - подробные логи (включая команды webinst)
# INFO - только основные события
# ERROR - только ошибки
# =========================================================
# Уровень логирования публикатора
PUBLISHER_LOG_LEVEL=DEBUG
# Путь к файлу логирования публикатора
PUBLISHER_LOG_PATH=G:/Automation/zbx-1c-py/logs
# ---------------------------------------------------------------------------
# APACHE DEPLOYMENT
# ---------------------------------------------------------------------------

# Версия Apache для загрузки
APACHE_VERSION=2.4.66

# Версия Visual Studio для Apache (VS16, VS17, VS18)
APACHE_VS=VS18

# URL для загрузки 
APACHE_DOWNLOAD_URL=https://www.apachelounge.com/download/VS18/binaries/httpd-2.4.66-260223-Win64-VS18.zip

# Альтернативный URL (fallback)
# APACHE_FALLBACK_URL=

# Пути установки Apache
# Windows: APACHE_INSTALL_PATH_WIN=C:/Apache24
# Linux:   APACHE_INSTALL_PATH_LINUX=/etc/apache2
APACHE_INSTALL_PATH_WIN=C:/Apache24
APACHE_INSTALL_PATH_LINUX=/etc/apache2

# Имя службы Apache
# Windows: APACHE_SERVICE_NAME=Apache2.4
# Linux:   APACHE_SERVICE_NAME=apache2
APACHE_SERVICE_NAME=Apache2.4

# Менеджер пакетов Linux (auto, apt, yum, dnf, pacman)
PACKAGE_MANAGER=auto
